# Copy to .env and adjust. docker-compose reads this automatically.
# NEVER commit a real .env — only this example belongs in git.

# --- Django core -------------------------------------------------------------
# Generate a real one for prod, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=dev-only-not-secret
# "1"/"true" enables DEBUG. MUST be 0/false in production.
DJANGO_DEBUG=1
# Comma-separated. K8s probes use Host: localhost (see manifests).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Database ----------------------------------------------------------------
# 12-factor single-URL form consumed by settings. For compose, host is "db".
DATABASE_URL=postgres://postgres:postgres@localhost:5432/backend_devops_interview

# Discrete parts used by the Postgres container + compose port mapping.
POSTGRES_DB=backend_devops_interview
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Host-side port for the Postgres container (container stays on 5432).
# Bump this (e.g. 5433) if you already run Postgres locally on 5432.
DB_PORT=5432

# --- Image (used by compose / Makefile) --------------------------------------
IMAGE=fintual-content-service
TAG=local
